{
    "version": 2,
    "functions": {
        "app.js": {
            "maxDuration": 30
        }
    },
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/app.js"
        }
    ],
    "crons": [
        {
            "path": "/ping",
            "schedule": "*/5 * * * *"
        }
    ]
}